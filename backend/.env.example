# =============================================================================
# Pack — environment template. Copy to .env and fill in real values.
# Real secrets are NEVER committed (.env is gitignored). Keys are server-side only.
# =============================================================================

# --- Qwen / Alibaba Cloud Model Studio (DashScope) ---
# The engine points the OpenAI SDK at Qwen's OpenAI-compatible endpoint.
# Region nearest Nigeria with Model Studio availability — verify in the console (D6).
# Singapore is the likely answer (Doc 04 §04, §07).
QWEN_API_KEY=sk-replace-me
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_REGION=ap-southeast-1

# Model-tier registry — verify the REAL model names in Model Studio on day 1 (F14).
# These are placeholders kept in config, never hard-coded (Doc 04 §04).
QWEN_MODEL_MAX=qwen-max
QWEN_MODEL_PLUS=qwen-plus
QWEN_MODEL_FLASH=qwen-flash

# --- Qwen voice model (transcription) — access checked now, contract freezes Jun 16 ---
# Fallback is Qwen ASR behind the same Transcriber interface (decision Jun 20, D7).
QWEN_VOICE_API_KEY=
QWEN_VOICE_BASE_URL=

# --- Redis (Tair on Alibaba Cloud) — the event-stream seam between engine & gateway ---
REDIS_URL=redis://localhost:6379/0

# --- Postgres (ApsaraDB RDS) — durable event archive + data model ---
POSTGRES_URL=postgresql://pack:pack@localhost:5432/pack

# --- OSS bucket (artifacts, uploads) — objects private, signed URLs only ---
OSS_BUCKET=
OSS_ENDPOINT=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# --- App ---
# Anonymous browser sessions only — no login in the hackathon build (D5).
SESSION_SECRET=change-me-in-prod
ENGINE_HOST=0.0.0.0
ENGINE_PORT=8000
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080

# First-hunt silent spend cap, USD (Doc 04 §04 / F7).
FIRST_HUNT_CAP_USD=0.50
