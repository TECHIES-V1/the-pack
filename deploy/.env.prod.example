# Pack — production environment. Copy to .env.prod on the server and fill in real values.
# NEVER commit .env.prod (gitignored). Secrets live only on the server.

# --- Qwen / Model Studio (DashScope, Singapore intl endpoint) ---
QWEN_API_KEY=sk-replace-me
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_REGION=ap-southeast-1
QWEN_MODEL_MAX=qwen-max
QWEN_MODEL_PLUS=qwen-plus
QWEN_MODEL_FLASH=qwen-flash

# --- ApsaraDB RDS for PostgreSQL (private VPC endpoint) ---
POSTGRES_URL=postgresql://pack:PASSWORD@your-rds-host:5432/pack
# "require" if RDS enforces TLS; empty if not.
POSTGRES_SSLMODE=require

# --- Tair / Redis (private VPC endpoint; plain redis:// within the VPC — no TLS needed) ---
REDIS_URL=redis://:PASSWORD@your-tair-host:6379/0

# --- App ---
FIRST_HUNT_CAP_USD=0.50
