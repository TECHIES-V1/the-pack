# Frontend env template. Copy to .env.local and fill in. Vite only exposes VITE_* vars to
# the client. NO secrets here — the frontend holds a session id only (Doc 03 §9). All Qwen
# keys live server-side in the backend.

# The Rust gateway's WebSocket stream endpoint (WS /hunts/:id/stream?from_seq=n).
VITE_GATEWAY_WS_URL=ws://localhost:8080

# The Python engine's REST base URL (commands: create hunt, approve plan, resolve hold…).
VITE_ENGINE_URL=http://localhost:8000
